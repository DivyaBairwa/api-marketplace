# Postgres connection string (e.g. from Neon or Supabase).
# Format: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string-please"
JWT_EXPIRES_IN="7d"

PORT=3000
NODE_ENV=development

# Comma-separated list of allowed origins for the frontend.
CORS_ORIGIN=http://localhost:5173

BCRYPT_COST=10
RATE_LIMIT_PER_SECOND=10
